PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/clientra?retryWrites=true&w=majority
MONGODB_CONNECT_RETRIES=5
MONGODB_RETRY_DELAY_MS=3000
MONGODB_CONNECT_TIMEOUT_MS=15000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=15000
MONGODB_SOCKET_TIMEOUT_MS=45000
JWT_SECRET=replace_this_with_a_long_random_secret
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional, only needed for forgot password emails.
GMAIL_USER=
GMAIL_PASS=
