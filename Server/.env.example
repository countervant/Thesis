PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/clientra?retryWrites=true&w=majority
MONGODB_CONNECT_RETRIES=5
MONGODB_RETRY_DELAY_MS=3000
MONGODB_CONNECT_TIMEOUT_MS=15000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=15000
MONGODB_SOCKET_TIMEOUT_MS=45000
JWT_SECRET=replace_this_with_a_long_random_secret
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional comma-separated regular expressions for preview deployments.
# Example: ^https://thesis-[a-z0-9]+-countervants-projects\.vercel\.app$
CORS_ORIGIN_PATTERNS=

# Production diagnostics are disabled by default. Only enable temporarily.
ENABLE_DATABASE_DIAGNOSTICS=false
DATABASE_DIAGNOSTICS_TOKEN=

# Optional, only needed for forgot password emails.
GMAIL_USER=
GMAIL_PASS=
